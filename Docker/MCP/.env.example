# mcp-uptime-kuma
UPTIME_KUMA_METRICS_URL=http://192.168.1.20:3001/metrics
UPTIME_KUMA_API_KEY=example_api_key
MCP_PORT=3100

# mcp-n8n (https://github.com/czlonkowski/n8n-mcp)
# Generate with: openssl rand -base64 32 — must match the value substituted
# into the Authorization header in the repo's root .mcp.json ($N8N_MCP_AUTH_TOKEN).
AUTH_TOKEN=generate_with_openssl_rand_base64_32
MCP_MODE=http
PORT=3000
LOG_LEVEL=info
# n8n API access (enables workflow create/update/deploy tools, not just node search/docs).
# Generate in n8n: Settings -> n8n API -> API Keys.
N8N_API_URL=http://192.168.1.20:5678
N8N_API_KEY=generate_in_n8n_settings_api
# Required for a self-hosted n8n on a private IP: n8n-mcp's SSRF guard blocks
# RFC1918 addresses by default. "permissive" allows localhost/private IPs;
# cloud metadata endpoints stay blocked in every mode. Not for public-facing use.
WEBHOOK_SECURITY_MODE=permissive
